set $mod Mod4

font pango:Proxima Nova 12

exec --no-startup-id dex --autostart --environment i3

exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

exec --no-startup-id nm-applet

exec --no-startup-id feh --bg-fill ~/Pictures/wallpaper.jpg || feh --bg-fill /usr/share/backgrounds/default.png

floating_modifier $mod

bindsym $mod+Return exec --no-startup-id kitty

bindsym $mod+Shift+q kill
bindsym $mod+Shift+v kill

exec_always --no-startup-id xset s off
exec_always --no-startup-id xset -dpms

bindsym $mod+d exec --no-startup-id rofi -show drun -font 'Hack 11'

bindsym $mod+m exec ~/.config/i3/scripts/powermenu

bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+b split h
bindsym $mod+n split v

bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+Shift+space floating toggle

bindsym $mod+space focus mode_toggle

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Right move workspace to output right
bindsym $mod+Left move workspace to output left
bindsym $mod+Up move workspace to output up
bindsym $mod+Down move workspace to output down

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume @DEFAULT_SINK@ 5%+ --limit 1.0 && pkill -RTMIN+1 i3blocks
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_SINK@ 5%- && pkill -RTMIN+1 i3blocks
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute @DEFAULT_SINK@ toggle && pkill -RTMIN+1 i3blocks
bindsym XF86AudioMicMute exec --no-startup-id wpctl set-mute @DEFAULT_SOURCE@ toggle

bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

bindsym Print exec flameshot gui

set $bg #282828
set $red #cc241d
set $green #98971a
set $yellow #d79921
set $blue #458588
set $purple #b16286
set $aqua #689d68
set $gray #a89984
set $darkgray #1d2021

client.focused          $green $green $darkgray $green $green
client.focused_inactive $darkgray $darkgray $yellow $darkgray $darkgray
client.unfocused        $darkgray $darkgray $yellow $darkgray $darkgray
client.urgent           $red $red $white $red $red

default_border pixel 2
gaps outer 3
gaps inner 6

bar {
    font pango:FiraCode Nerd Font 12, DejaVu Sans Mono 12
    status_command i3blocks -c ~/.config/i3/i3blocks.conf
    position bottom
    i3bar_command i3bar --transparency
    
    colors {
        background $bg
        statusline $yellow
        focused_workspace    $aqua $aqua $darkgray
        inactive_workspace   $bg $bg $yellow
        active_workspace     $bg $bg $yellow
        urgent_workspace     $red $red $bg
    }
}

exec_always --no-startup-id picom --config ~/.config/picom/picom.conf --backend glx --vsync
