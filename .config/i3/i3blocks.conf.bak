separator=false
markup=pango
separator_block_width=15
color=#ebdbb2

[cpu_usage]
label= 
command=~/.config/i3/scripts/miei/cpu.sh
interval=10
color=#83a598

[separator]
full_text=⟨
color=#a89984

[memory]
label=󰍛 
command=free -h | awk '/^Mem:/ {print $3 "/" $2}'
interval=30
color=#fb4934

[separator]
full_text=⟨
color=#a89984

[volume-pulseaudio]
command=~/.config/i3/scripts/volume
instance=Master
interval=once
signal=1
color=#fab387

[separator]
full_text=⟨
color=#a89984

[bluetooth]
command=~/.config/i3/scripts/bluetooth.sh
interval=10
color=#83a598

[separator]
full_text=⟨
color=#a89984

[wifi]
command=~/.config/i3/scripts/wifi.sh
interval=10
color=#b8bb26

[separator]
full_text=⟨
color=#a89984

[battery]
command=~/.config/i3/scripts/battery.sh
interval=30

[separator]
full_text=⟨
color=#a89984

[time]
command=date '+%a %d %b  %H:%M'
interval=1
color=#ebdbb2

[separator]
full_text=⟨
color=#a89984

[shutdown_menu]
full_text=⏼ 
command=~/.config/i3/scripts/powermenu
color=#fb4934
